---
// Renders a resource collection as a card grid, optionally grouped by `format`.
// Includes a filter-chip bar above the grid: clicking a chip narrows the visible
// groups to a single format via client-side JS (no page reload). When only one
// format is present the chip bar is suppressed so it doesn't read as noise.

import { getCollection, render } from "astro:content";
import Card from "./Card.astro";

interface Props {
  collection: "practice" | "tools" | "reading-list" | "events" | "community";
  formatOrder?: string[];
  groupHeadings?: Record<string, string>;
  limit?: number;
  showFilters?: boolean;
}

const {
  collection,
  formatOrder,
  groupHeadings = {},
  limit,
  showFilters = true,
} = Astro.props;

const entries = await getCollection(collection);
entries.sort(
  (a, b) =>
    (a.data.order ?? 999) - (b.data.order ?? 999) ||
    a.data.title.localeCompare(b.data.title),
);

const order =
  formatOrder ?? Array.from(new Set(entries.map((e) => e.data.format)));

const groups: { format: string; heading: string; items: typeof entries }[] = [];
for (const fmt of order) {
  const items = entries.filter((e) => e.data.format === fmt);
  if (items.length === 0) continue;
  const heading = groupHeadings[fmt] ?? fmt;
  groups.push({
    format: fmt,
    heading,
    items: limit ? items.slice(0, limit) : items,
  });
}

const totalItems = groups.reduce((sum, g) => sum + g.items.length, 0);

const rendered = await Promise.all(
  groups.flatMap((g) => g.items).map(async (entry) => {
    const { Content } = await render(entry);
    return [entry.id, Content] as const;
  }),
);
const bodyMap = new Map(rendered);

const showChips = showFilters && groups.length > 1;
---

<div class="section-grid container" data-grid>
  {showChips && (
    <nav class="filter-bar" aria-label="Filter by format">
      <button type="button" class="chip active" data-filter="all">
        All <span class="chip-count">{totalItems}</span>
      </button>
      {groups.map((g) => (
        <button type="button" class="chip" data-filter={g.format}>
          {g.heading} <span class="chip-count">{g.items.length}</span>
        </button>
      ))}
    </nav>
  )}

  {groups.map((group) => (
    <section class="format-group" data-format={group.format}>
      <h2 class="group-heading">
        {group.heading}
        <span class="count muted">({group.items.length})</span>
      </h2>
      <div class="grid">
        {group.items.map((entry) => {
          const Body = bodyMap.get(entry.id);
          return (
            <Card
              title={entry.data.title}
              format={entry.data.format}
              url={entry.data.url}
              venue={entry.data.venue}
              authors={entry.data.authors}
              year={entry.data.year}
              cluster={entry.data.cluster}
              topics={entry.data.topics}
              tags={entry.data.tags}
              missingProvenance={entry.data.missingProvenance}
              summary={entry.data.summary}
              embed={entry.data.embed}
              speakerImage={entry.data.speakerImage}
              speakerName={entry.data.speakerName}
            >
              {Body && <Body />}
            </Card>
          );
        })}
      </div>
    </section>
  ))}
</div>

{showChips && (
  <script is:inline>
    // Filter-chip behavior: clicking a chip narrows visible .format-group
    // children of its containing [data-grid]. Each grid is independent.
    (function () {
      var bars = document.querySelectorAll('[data-grid] .filter-bar');
      bars.forEach(function (bar) {
        var grid = bar.closest('[data-grid]');
        if (!grid) return;
        bar.addEventListener('click', function (e) {
          var btn = e.target.closest('.chip');
          if (!btn) return;
          bar.querySelectorAll('.chip').forEach(function (c) { c.classList.remove('active'); });
          btn.classList.add('active');
          var filter = btn.getAttribute('data-filter');
          grid.querySelectorAll('.format-group').forEach(function (g) {
            if (filter === 'all' || g.getAttribute('data-format') === filter) {
              g.removeAttribute('hidden');
            } else {
              g.setAttribute('hidden', '');
            }
          });
          // Smooth scroll to top of grid so the chosen group is visible.
          var top = grid.getBoundingClientRect().top + window.scrollY - 80;
          window.scrollTo({ top: top, behavior: 'smooth' });
        });
      });
    })();
  </script>
)}

<style>
  .section-grid {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  .format-group { display: flex; flex-direction: column; gap: 1rem; }
  .group-heading {
    font-family: var(--serif);
    font-size: 1.2rem;
    font-weight: 600;
    margin: 0;
    padding-bottom: .5rem;
    border-bottom: 1px solid var(--border);
    text-transform: capitalize;
  }
  .count { font-size: .9rem; font-weight: 400; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 18rem), 1fr));
    gap: 1rem;
  }

  /* Filter chip bar */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: .4rem;
    padding-bottom: .5rem;
    margin-bottom: -.5rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 1rem;
    margin-bottom: 0;
  }
  .chip {
    font-family: var(--sans);
    font-size: .82rem;
    font-weight: 500;
    color: var(--ink-soft);
    background: var(--tint);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: .35rem .85rem .4rem;
    cursor: pointer;
    transition: background .15s ease, color .15s ease, border-color .15s ease;
    text-transform: capitalize;
    letter-spacing: .01em;
    display: inline-flex;
    align-items: baseline;
    gap: .4rem;
  }
  .chip:hover { background: var(--tint-warm); color: var(--accent); border-color: var(--accent); }
  .chip.active {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
  }
  .chip-count {
    font-size: .72rem;
    font-weight: 400;
    color: inherit;
    opacity: .7;
  }
  .chip.active .chip-count { opacity: .85; }
</style>
