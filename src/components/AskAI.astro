---
// AskAI — a sparkle affordance that opens an AI assistant in a new tab,
// prefilled with a prompt tailored to this case (its facts plus the LENS
// reading). The site is static, so this deep-links to the assistant's
// new-chat query parameter rather than generating anything in-page; no API
// key or backend is involved. `variant="icon"` is the compact card control;
// `variant="button"` is the labelled control for the detail page.

interface Props {
  title: string;
  year: string;
  /** One-line factual context (the case's impact line). */
  context: string;
  /** The learning-engineering reading, to steer the conversation. */
  lensReading: string;
  variant?: "icon" | "button";
}

const { title, year, context, lensReading, variant = "icon" } = Astro.props;

// A self-contained prompt: the assistant needs no prior page context, so the
// case's own facts and LENS reading travel inside the query string.
const prompt = [
  `I'm reading a LENS (Learning Engineering for Next-Generation Systems) case study on "${title}" (${year}).`,
  `In brief: ${context}`,
  `The learning-engineering reading is: ${lensReading}`,
  `Help me understand the capability lesson here and how it applies to designing or evaluating a system I work on.`,
].join("\n\n");

const href = `https://claude.ai/new?q=${encodeURIComponent(prompt)}`;
const label = "Ask AI about this case";
---

<a
  class:list={["ask-ai", variant]}
  href={href}
  target="_blank"
  rel="noopener"
  aria-label={label}
  title={label}
>
  <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" focusable="false">
    <path
      d="M12 3l1.6 4.4L18 9l-4.4 1.6L12 15l-1.6-4.4L6 9l4.4-1.6L12 3z"
      fill="currentColor"
    />
    <path d="M18.5 14l.7 1.9 1.9.7-1.9.7-.7 1.9-.7-1.9-1.9-.7 1.9-.7.7-1.9z" fill="currentColor" opacity="0.7" />
  </svg>
  {variant === "button" && <span>Ask AI about this case</span>}
</a>

<style>
  .ask-ai {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--accent-2);
    border: none;
    font-family: var(--sans);
    line-height: 1;
    transition: color 0.15s ease, background 0.15s ease;
  }
  /* Compact icon control used on cards. */
  .ask-ai.icon {
    justify-content: center;
    width: 1.9rem;
    height: 1.9rem;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--bg);
  }
  .ask-ai.icon:hover {
    color: #fff;
    background: var(--accent-2);
    border-color: var(--accent-2);
  }
  /* Labelled control used on the detail page. */
  .ask-ai.button {
    font-size: 0.82rem;
    font-weight: 600;
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--accent-2);
    border-radius: 4px;
  }
  .ask-ai.button:hover { color: #fff; background: var(--accent-2); }
</style>
