---
// LecommonsCallout.astro — points readers to the full IEEE ICICLE / Learning
// Engineering Commons corpus at lecommons, which this site draws from but
// does not host. Used on collection pages that were trimmed to a small
// JHU/LENS-specific slice so the rest of the field's work stays one click away.

interface Props {
  path?: string;
  label: string;
}

const { path = "", label } = Astro.props;
const LECOMMONS_URL = "https://wrgr.github.io/lecommons/";
---

<section class="lecommons-callout">
  <div class="container">
    <p>
      <strong>capabilitymatters</strong> stays focused on the JHU LENS program.
      For {label}, visit the <a href={`${LECOMMONS_URL}${path}`} target="_blank" rel="noopener">Learning Engineering Commons</a> —
      the shared IEEE ICICLE corpus this site connects to but doesn't own.
    </p>
  </div>
</section>

<style>
  .lecommons-callout {
    background: var(--tint);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .lecommons-callout .container {
    padding: 1rem var(--page-pad);
    max-width: 72rem;
    margin: 0 auto;
  }
  .lecommons-callout p {
    margin: 0;
    font-family: var(--sans);
    font-size: .92rem;
    color: var(--ink-soft);
    max-width: var(--measure);
  }
  .lecommons-callout a {
    color: var(--accent-2);
    font-weight: 600;
  }
</style>
