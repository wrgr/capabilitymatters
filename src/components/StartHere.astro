---
// StartHere.astro — editorial "start here" panel for section pages.
//
// Surfaces 2–3 hand-picked items from a section's collection with a per-pick
// one-liner ("if you're new, read this", "best one-paragraph overview", etc.).
// Notes are passed inline by the page so the same item can be framed
// differently in different contexts (the editorial framing belongs to the
// page, not the content file).
//
// Picks resolve by entry id (the filename without the .mdx extension). An
// unmatched slug is silently dropped — keeps the page from crashing if a
// content file is renamed or removed.

import { getCollection } from "astro:content";

interface Pick {
  slug: string;
  note: string;
}

interface Props {
  collection: "practice" | "tools" | "reading-list" | "events" | "community";
  picks: Pick[];
  eyebrow?: string;
  title?: string;
  lede?: string;
}

const {
  collection,
  picks,
  eyebrow = "Start here",
  title = "Three to read first",
  lede,
} = Astro.props;

const entries = await getCollection(collection);

const items = picks
  .map((p) => {
    const entry = entries.find((e) => e.id === p.slug);
    return entry ? { entry, note: p.note } : null;
  })
  .filter((x): x is { entry: (typeof entries)[number]; note: string } => x !== null);
---

{items.length > 0 && (
  <section class="start-here">
    <div class="container">
      <div class="eyebrow">{eyebrow}</div>
      <h2 class="start-title">{title}</h2>
      {lede && <p class="start-lede">{lede}</p>}
      <ul class="picks">
        {items.map(({ entry, note }) => {
          const href = entry.data.url;
          const meta = [
            entry.data.format,
            entry.data.authors,
            entry.data.year ? String(entry.data.year) : undefined,
          ].filter(Boolean);
          return (
            <li class="pick">
              {href ? (
                <a href={href} target="_blank" rel="noopener" class="pick-link">
                  <div class="pick-note">{note}</div>
                  <div class="pick-title">{entry.data.title} <span class="arrow">→</span></div>
                  {meta.length > 0 && <div class="pick-meta">{meta.join(" · ")}</div>}
                </a>
              ) : (
                <div class="pick-link pick-link--static">
                  <div class="pick-note">{note}</div>
                  <div class="pick-title">{entry.data.title}</div>
                  {meta.length > 0 && <div class="pick-meta">{meta.join(" · ")}</div>}
                </div>
              )}
            </li>
          );
        })}
      </ul>
    </div>
  </section>
)}

<style>
  .start-here {
    background: var(--tint-warm);
    border-bottom: 1px solid var(--border);
  }
  .start-here .container {
    padding-top: 2.2rem;
    padding-bottom: 2.4rem;
  }
  .start-title {
    font-family: var(--serif);
    font-size: clamp(1.4rem, 2.4vw, 1.7rem);
    font-weight: 600;
    margin: 0 0 .6rem 0;
    letter-spacing: -0.005em;
  }
  .start-lede {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1rem;
    color: var(--ink-soft);
    max-width: var(--measure);
    margin: 0 0 1.4rem;
  }
  .picks {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 17rem), 1fr));
    gap: 1rem;
  }
  .pick { display: flex; }
  .pick-link {
    display: flex;
    flex-direction: column;
    gap: .4rem;
    padding: 1.1rem 1.2rem 1.2rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent-2);
    border-radius: 4px;
    color: var(--ink);
    width: 100%;
    transition: transform .15s ease, border-color .15s ease, box-shadow .15s ease;
  }
  .pick-link:hover {
    border-color: var(--accent-2);
    border-left-color: var(--accent-2);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(26, 29, 26, 0.06);
  }
  .pick-link--static { cursor: default; }
  .pick-link--static:hover { transform: none; box-shadow: none; border-color: var(--border); }

  .pick-note {
    font-family: var(--serif);
    font-style: italic;
    font-size: .95rem;
    color: var(--accent-2);
    line-height: 1.4;
  }
  .pick-title {
    font-family: var(--serif);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.3;
  }
  .arrow { color: var(--accent-2); font-weight: 400; }
  .pick-meta {
    font-family: var(--sans);
    font-size: .78rem;
    color: var(--muted);
    margin-top: .1rem;
  }

  @media (max-width: 560px) {
    .start-here .container { padding-top: 1.8rem; padding-bottom: 2rem; }
  }
</style>
