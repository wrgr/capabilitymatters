---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;

const counts = {
  practice:      (await getCollection("practice")).length,
  tools:         (await getCollection("tools")).length,
  "field-notes": (await getCollection("field-notes")).filter((p) => !p.data.draft).length,
  "reading-list":(await getCollection("reading-list")).length,
  events:        (await getCollection("events")).length,
  community:     (await getCollection("community")).length,
};

type SectionKey = keyof typeof counts;

const discoveryCards: { href: string; lead: string; title: string; detail: string }[] = [
  {
    href: base + "topics/",
    lead: "Exploring by topic?",
    title: "Topics",
    detail: "Browse 18 topics across three layers — from learning science foundations to ethics and evidence standards.",
  },
  {
    href: base + "pathways/",
    lead: "Want a guided tour?",
    title: "Pathways",
    detail: "Five narrative threads through the field — follow the one that matches your question.",
  },
];

const whyCards: { key: SectionKey; href: string; lead: string; title: string; detail: string }[] = [
  {
    key: "field-notes",
    href: base + "field-notes/",
    lead: "Need something you can use this week?",
    title: "Field Notes",
    detail: "Short practitioner pieces — tips, templates, and lessons from the actual work.",
  },
  {
    key: "practice",
    href: base + "practice/",
    lead: "Figuring out how LEs structure their work?",
    title: "Practice",
    detail: "Process diagrams, maturity models, and analysis methods (Five Whys, Fishbone, task analysis).",
  },
  {
    key: "community",
    href: base + "community/",
    lead: "Looking for people or programs?",
    title: "Community",
    detail: "Organizations, degree programs, and practitioners who do this work.",
  },
  {
    key: "events",
    href: base + "events/",
    lead: "Planning to attend, present, or catch up?",
    title: "Events",
    detail: "Conferences, recurring series, keynotes, podcasts, and talks from the field.",
  },
  {
    key: "reading-list",
    href: base + "reading-list/",
    lead: "Scanning the field or citing the literature?",
    title: "Reading List",
    detail: "Papers, books, articles, and reports that define the evidence base.",
  },
  {
    key: "tools",
    href: base + "tools/",
    lead: "Picking a platform or instrumenting something?",
    title: "Tools",
    detail: "The platforms, systems, and software LEs build on.",
  },
];

const programGoals: string[] = [
  "Prepare practitioners with evidence-driven, methodological skills to instrument learning environments, analyze performance data, and produce decision-grade evidence linking learning outcomes to operational performance.",
  "Develop analytical and professional skills to responsibly design, deploy, and improve solutions that address critical customer needs, applying implementation science and continuous improvement cycles to integrate human and system capabilities effectively.",
  "Develop professionals who can navigate the requirements of complex, high-stakes environments, treating privacy, bias, ethics, and accountability as design constraints.",
  "Enhance capabilities to leverage emerging technologies, including artificial intelligence, and to interpret results and risks responsibly, with attention to uncertainty and auditability.",
  "Advance the learning engineering field by applying rigorous methods to authentic operational problems in coursework and capstone projects, contributing new evidence on effectiveness.",
];
---

<Base
  title="LENS — Learning Engineering for Next-Generation Systems"
  description="A Johns Hopkins program engineering human capability for the complex systems where it matters most."
  active="welcome"
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <div class="eyebrow">Engineering human capability · Advancing system performance</div>
        <h1 class="lede">
          Traditional instructional design optimizes individual learning experiences.
          Learning engineering treats capability as a system-level problem.
        </h1>
        <p class="subhead">
          In healthcare, defense, public infrastructure, and other high-stakes domains, the gap
          between human performance and system performance is consequential — and largely
          unaddressed by the tools and frameworks instructional traditions provide.
          <strong>LENS</strong> is the Johns Hopkins specialization built to close that gap.
        </p>
      </div>
      <aside class="hero-graphic" aria-hidden="true">
        <img src={base + "lecommons.jpg"} alt="" class="hero-image" />
      </aside>
    </div>
  </section>

  <hr class="rule-in-container" />

  <section class="capability-gap">
    <div class="container two-col">
      <div>
        <div class="eyebrow">The capability gap</div>
        <h2>Why a new program, and why now</h2>
        <p>
          Learning engineering is an emerging practice and discipline that applies the learning
          sciences through engineering methods and data-informed decision making to design,
          implement, and continuously improve systems that develop human capability. Where
          traditional instructional design focuses on the quality of individual learning
          experiences, learning engineering treats capability development as a system-level
          problem — one that requires rigorous evidence, iterative improvement, and integration
          across the full lifecycle of complex systems.
        </p>
        <p>
          Many academic programs in the learning sciences and learning engineering are organized
          around designed instructional contexts: schools, universities, and edtech products.
          These are essential domains, but they represent only a fraction of the environments
          where human capability development is operationally critical. In healthcare systems,
          defense enterprises, public infrastructure, and other high-stakes organizations, the
          gap between human performance and system performance is consequential — and it
          remains largely unaddressed by the tools and frameworks that instructional traditions
          provide.
        </p>
      </div>
      <aside class="pull-quotes">
        <blockquote>
          "Learning engineering is a process and practice that applies the learning sciences using
          human-centered engineering design methodologies and data-informed decision-making to
          support learners and their development."
          <cite>— IEEE ICICLE definition</cite>
        </blockquote>
      </aside>
    </div>
  </section>

  <section class="about-lens">
    <div class="container">
      <div class="eyebrow">About LENS</div>
      <h2>Treating human capability as a core engineering function</h2>
      <p>
        LENS is built for that gap. Aligned with emerging IEEE ICICLE learning engineering
        standards, it prepares graduates to treat human capability not as an instructional
        afterthought but as a core engineering function that must be designed into complex
        systems from the outset and sustained across the system lifecycle. LENS graduates will
        operate fluently at the intersection of the learning sciences and systems engineering,
        able to work across the disciplinary boundaries that currently leave the human side of
        complex domains neglected at measurable cost to system performance.
      </p>
      <p>
        Within the LDT program, LENS is the specialization most directly oriented toward
        high-stakes, operationally complex environments — including healthcare, defense, and
        education itself when understood as a complex system rather than as a collection of
        instructional events. Learning engineering is emerging as a profession and academic
        discipline; LENS graduates will enter the workforce at a formative moment, positioned
        not just to practice learning engineering but to help define it.
      </p>

      <h3 class="goals-heading">Program goals</h3>
      <ol class="program-goals">
        {programGoals.map((goal) => <li>{goal}</li>)}
      </ol>
    </div>
  </section>

  <section class="why-here">
    <div class="container">
      <div class="eyebrow">Resources</div>
      <h2>Curated learning engineering resources, in context</h2>
      <p class="resources-intro">
        Alongside the program, this site hosts a curated set of learning engineering resources —
        practitioner notes, methods, reading, tools, events, and community references — adapted
        from the Learning Engineering Commons and aligned with the
        <a href="https://sagroups.ieee.org/icicle/" target="_blank" rel="noopener">IEEE ICICLE</a>
        community. They are presented here as supporting context for the LENS thesis: the field
        students and practitioners are entering, and the evidence base they will build on.
      </p>
      <ul class="why-list why-list--discovery">
        {discoveryCards.map((c) => (
          <li>
            <a href={c.href} class="why-card why-card--discovery">
              <div class="why-lead">{c.lead}</div>
              <div class="why-title">{c.title} →</div>
              <div class="why-detail">{c.detail}</div>
            </a>
          </li>
        ))}
      </ul>
      <h3 class="browse-heading">Or browse by what you need</h3>
      <ul class="why-list">
        {whyCards.map((c) => (
          <li>
            <a href={c.href} class="why-card">
              <div class="why-lead">{c.lead}</div>
              <div class="why-title">{c.title} <span class="why-count">({counts[c.key]})</span> →</div>
              <div class="why-detail">{c.detail}</div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="audiences">
    <div class="container">
      <h2>Who this is for</h2>
      <ul class="audience-list">
        <li>
          <strong>Prospective LENS students</strong> evaluating whether the program fits the
          problem they want to work on — and what they would graduate able to do.
        </li>
        <li>
          <strong>Practitioners in high-stakes domains</strong> (healthcare, defense, public
          infrastructure) who recognize the capability gap and want a vocabulary, evidence
          base, and peer community for closing it.
        </li>
        <li>
          <strong>Adjacent professionals</strong> — instructional designers, ML engineers,
          learning scientists, HR/L&D leaders, systems engineers — who need to understand how
          learning engineering overlaps with what they already do.
        </li>
      </ul>
    </div>
  </section>

  <section class="about-site">
    <div class="container">
      <h2>About this site</h2>
      <p>
        The Resources section draws on a hand-curated workbook of IEEE ICICLE–adjacent material
        originally assembled as the <em>Learning Engineering Commons</em>, plus original
        practitioner posts in Field Notes. Items are tagged by format and by curatorial cluster
        (e.g. "ICICLE resources," "Bror Saxberg," "I/ITSEC"). Sources with incomplete provenance
        carry a visible <em>source unknown</em> badge — we'd rather show you a promising lead we
        haven't verified than quietly drop it.
        <a href={base + "about/"}>More on scope &amp; method →</a>
      </p>
    </div>
  </section>
</Base>

<style>
  .hero {
    background:
      radial-gradient(42rem 16rem at 88% -5%, #f7f1e3 0%, transparent 70%),
      radial-gradient(28rem 14rem at 9% -20%, #f1ece1 0%, transparent 75%),
      var(--bg);
    border-bottom: 1px solid var(--border);
  }
  .hero .container {
    padding-top: 4rem;
    padding-bottom: 2rem;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(22rem, 1.1fr);
    align-items: center;
    gap: clamp(1.2rem, 3vw, 2.4rem);
  }
  .hero-copy {
    position: relative;
    z-index: 1;
  }
  .lede {
    font-family: var(--serif);
    font-size: clamp(1.6rem, 3.2vw, 2.4rem);
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.005em;
    max-width: 40rem;
    color: var(--ink);
    margin: 0 0 1.2rem 0;
  }
  .subhead {
    font-size: 1.1rem;
    color: var(--ink-soft);
    max-width: 40rem;
    line-height: 1.55;
  }
  .subhead strong { color: var(--accent); font-weight: 600; }
  .hero-graphic {
    justify-self: end;
    width: min(100%, 34rem);
    padding: .35rem;
    border-radius: 3px;
    background: #f8f4ea;
    border: 1px solid #ddd4c5;
    box-shadow: 0 10px 28px rgba(32, 31, 25, 0.12);
    overflow: hidden;
    animation: liftIn .42s ease-out both;
  }
  .hero-image {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 2px;
  }

  @keyframes liftIn {
    from {
      transform: translateY(10px);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  .rule-in-container {
    max-width: 60rem;
    margin: 0 auto;
    border: none;
    border-top: 1px solid var(--border);
  }

  /* ── Capability gap section ──────────────────────────────────────────── */
  .capability-gap { margin-top: 1rem; }
  .capability-gap h2 {
    font-size: clamp(1.3rem, 2.4vw, 1.6rem);
    margin-bottom: 1rem;
    max-width: 36rem;
  }
  .two-col {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  @media (max-width: 780px) {
    .two-col { grid-template-columns: 1fr; gap: 1.5rem; }
  }
  .pull-quotes {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    border-left: 2px solid var(--accent);
    padding: .2rem 0 .2rem 1.2rem;
  }
  blockquote {
    margin: 0;
    font-family: var(--serif);
    font-size: 1rem;
    font-style: italic;
    color: var(--ink-soft);
    line-height: 1.5;
  }
  blockquote cite {
    display: block;
    margin-top: .5rem;
    font-style: normal;
    font-size: .85rem;
    color: var(--muted);
    font-family: var(--sans);
  }

  /* ── About LENS section ──────────────────────────────────────────────── */
  .about-lens {
    background: var(--tint);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-top: 2rem;
  }
  .about-lens .container { padding-top: 2.5rem; padding-bottom: 2.5rem; }
  .about-lens h2 {
    font-size: clamp(1.3rem, 2.4vw, 1.6rem);
    margin-bottom: 1rem;
    max-width: 36rem;
  }
  .goals-heading {
    font-family: var(--serif);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--ink);
    margin: 2rem 0 .75rem;
  }
  .program-goals {
    margin: 0;
    padding-left: 1.25rem;
    max-width: 48rem;
    display: flex;
    flex-direction: column;
    gap: .65rem;
  }
  .program-goals li {
    font-size: .95rem;
    line-height: 1.55;
    color: var(--ink-soft);
  }

  /* ── Resources (formerly "why here") ─────────────────────────────────── */
  .why-here { padding-top: 1rem; }
  .why-here h2 {
    font-size: clamp(1.3rem, 2.4vw, 1.6rem);
    margin-bottom: .8rem;
    max-width: 36rem;
  }
  .resources-intro {
    font-size: .98rem;
    color: var(--ink-soft);
    max-width: 44rem;
    margin: 0 0 1.6rem 0;
    line-height: 1.55;
  }
  .why-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
    gap: 1rem;
  }
  .why-list--discovery {
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
    margin-bottom: 1.8rem;
  }
  .why-card--discovery {
    border-top-color: var(--accent-2);
    background: var(--tint);
  }
  .why-card--discovery .why-title { color: var(--accent-2); }
  .browse-heading {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 500;
    color: var(--ink-soft);
    margin: 0 0 1rem;
  }
  .why-card {
    display: flex;
    flex-direction: column;
    gap: .5rem;
    padding: 1.2rem 1.25rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    border-top: 3px solid var(--accent);
    color: var(--ink);
    transition: transform .15s ease, border-color .15s ease;
    height: 100%;
  }
  .why-card:hover {
    transform: translateY(-1px);
    border-color: var(--accent);
    border-top-color: var(--accent);
  }
  .why-lead {
    font-family: var(--serif);
    font-size: .95rem;
    color: var(--ink-soft);
    font-style: italic;
  }
  .why-title {
    font-family: var(--serif);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--accent);
  }
  .why-count { color: var(--muted); font-weight: 400; font-size: .9rem; }
  .why-detail {
    font-family: var(--sans);
    font-size: .85rem;
    color: var(--muted);
    line-height: 1.45;
  }

  /* ── Audiences ───────────────────────────────────────────────────────── */
  .audiences {
    background: var(--tint);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-top: 3rem;
  }
  .audiences .container { padding-top: 2.5rem; padding-bottom: 2.5rem; }
  .audience-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
    gap: 1.2rem;
  }
  .audience-list li {
    font-size: .98rem;
    line-height: 1.55;
    color: var(--ink-soft);
  }
  .audience-list strong { color: var(--accent); font-weight: 600; }

  /* ── About this site ─────────────────────────────────────────────────── */
  .about-site { margin-top: 2.5rem; padding-bottom: 2rem; }
  .about-site p { font-size: .95rem; color: var(--ink-soft); max-width: 44rem; }

  @media (max-width: 900px) {
    .hero .container { padding-top: 3rem; }
    .hero-grid {
      grid-template-columns: 1fr;
      align-items: start;
      gap: 1.2rem;
    }
    .hero-graphic {
      justify-self: start;
      width: min(100%, 36rem);
    }
  }

  @media (max-width: 560px) {
    .hero .container {
      padding-top: 2.3rem;
      padding-bottom: 1.5rem;
    }
    .hero-graphic {
      border-radius: 2px;
      box-shadow: 0 8px 20px rgba(32, 31, 25, 0.09);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-graphic { animation: none; }
  }
</style>
