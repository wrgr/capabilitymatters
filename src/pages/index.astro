---
// Homepage: dark navy "Capability is a system parameter" landing experience.
// Uses Base with pageTheme="dark" so the NavBar + footer render on a dark
// chrome. Interior pages keep the default cream/Charter shell.
import Base from "../layouts/Base.astro";

const base = import.meta.env.BASE_URL;
const LENS_PROGRAM_URL =
  "https://education.jhu.edu/masters-programs/master-of-education-in-learning-design-and-technology/learning-engineering-next-generation-systems-concentration/";
const LECOMMONS_URL = "https://lecommons.org";
const OVERVIEW_PDF_URL = base + "LENS_Overview_May2026.pdf";
---

<Base
  title="Capability Matters — LENS at Johns Hopkins"
  description="Capability is a system parameter. LENS is the Johns Hopkins specialization that engineers human capability into complex systems."
  active="welcome"
  pageTheme="dark"
>
  <link
    slot="head"
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400&display=swap"
  />

  <section class="hero">
    <div class="hero-label">Learning Engineering for Next-Generation Systems</div>
    <h1>Capability is a <em>system parameter</em></h1>
    <p class="hero-sub">
      Every complex system depends on what people can do inside it.
      That dependency is measurable, designable, and too important to leave to chance.
    </p>
    <div class="hero-line"></div>
    <div class="scroll-cue" aria-hidden="true">
      <div class="line"></div>
      The argument
    </div>
  </section>

  <section class="statement reveal" id="argument">
    <div class="statement-number">01</div>
    <h2>Systems don't fail because the technology breaks. They fail because <em>someone couldn't do what the system required.</em></h2>
    <p>
      The operator who misreads a display under stress. The clinician who wasn't trained on the new protocol. The maintenance team that lost institutional knowledge when three people retired. These aren't edge cases. They're the norm.
    </p>
  </section>

  <section class="statement right reveal">
    <div class="statement-number">02</div>
    <h2>We engineer every parameter of a system <em>except the people.</em></h2>
    <p>
      Hardware gets reliability analysis. Software gets tested to specification. Human capability gets a training program bolted on at the end. Then we wonder why the system underperforms.
    </p>
  </section>

  <section class="statement reveal">
    <div class="statement-number">03</div>
    <h2>Capability is not a <em>soft</em> problem. It's a systems engineering problem.</h2>
    <p>
      How people develop, retain, and transfer operational competence is as tractable as any other engineering domain—when you bring the right methods, the right evidence, and the right integration into the system lifecycle.
    </p>
  </section>

  <section class="evidence-strip">
    <div class="evidence-cell reveal">
      <div class="num">250K+</div>
      <div class="unit">deaths per year</div>
      <p>from medical errors in the U.S.—the third leading cause of death. Not individual mistakes: system-wide failings and poorly coordinated care.</p>
      <div class="cite">Makary &amp; Daniel, <em>BMJ</em>, 2016 · Johns Hopkins</div>
    </div>
    <div class="evidence-cell reveal">
      <div class="num">~10yr</div>
      <div class="unit">of unmet training requirements</div>
      <p>The Marine Corps has been unable to meet training requirements in the Indo-Pacific—the theater the National Defense Strategy designates as DoD's top priority.</p>
      <div class="cite">GAO-24-107463 · 2022 National Defense Strategy</div>
    </div>
    <div class="evidence-cell reveal">
      <div class="num">$100M</div>
      <div class="unit">spent, then shut down in 14 months</div>
      <p>inBloom collapsed not because the technology failed—but because governance, privacy, and stakeholder trust were treated as afterthoughts, not design constraints.</p>
      <div class="cite">Data &amp; Society, 2017 · Education Week · 9 states withdrew</div>
    </div>
  </section>

  <section class="statement right reveal">
    <div class="statement-number">04</div>
    <h2>Decision-grade evidence. <em>Not opinions about training.</em></h2>
    <p>
      Can you prove your people are ready? Not with completion rates or satisfaction scores. With evidence that links learning interventions to operational outcomes—evidence rigorous enough to drive design decisions.
    </p>
  </section>

  <section class="domains" id="domains">
    <div class="domains-header reveal">
      <h2>High-consequence, high-impact domains</h2>
      <p>Where human capability is inseparable from system performance—and the cost of getting it wrong is measured in lives, readiness, and equity.</p>
    </div>
    <div class="domain-cards">
      <div class="domain-card reveal">
        <div class="icon" aria-hidden="true">⚕</div>
        <h3>Healthcare</h3>
        <p>Clinical teams navigating new protocols, devices, and care models under conditions where errors compound and learning can't wait.</p>
      </div>
      <div class="domain-card reveal">
        <div class="icon" aria-hidden="true">⛨</div>
        <h3>Defense &amp; National Security</h3>
        <p>Operators, maintainers, and analysts whose readiness determines whether billion-dollar systems achieve their intended effect.</p>
      </div>
      <div class="domain-card reveal">
        <div class="icon" aria-hidden="true">◈</div>
        <h3>Education at Scale</h3>
        <p>Systems serving millions of learners, where design decisions ripple across institutions and equity is a structural concern, not an afterthought.</p>
      </div>
      <div class="domain-card reveal">
        <div class="icon" aria-hidden="true">✈</div>
        <h3>Aviation</h3>
        <p>Flight crews, controllers, and maintenance teams working to tight margins, where procedural discipline and crew coordination decide the outcome.</p>
      </div>
      <div class="domain-card reveal">
        <div class="icon" aria-hidden="true">⚡</div>
        <h3>Energy</h3>
        <p>Operators of grids, refineries, and offshore platforms, where a single lapse in a high-hazard process can cascade into catastrophe.</p>
      </div>
      <div class="domain-card reveal">
        <div class="icon" aria-hidden="true">⚙</div>
        <h3>Manufacturing &amp; Industrial</h3>
        <p>Production teams sustaining quality and safety at scale, where tacit expertise and continuous improvement keep complex processes stable.</p>
      </div>
      <div class="domain-card reveal">
        <div class="icon" aria-hidden="true">⬡</div>
        <h3>Government &amp; Public Infrastructure</h3>
        <p>Public-sector programs and large IT modernizations, where governance, trust, and workforce readiness decide whether services reach the people who depend on them.</p>
      </div>
    </div>
  </section>

  <section class="cta-section" id="connect">
    <div class="cta-equation reveal">Human + System = Impact</div>
    <h2 class="reveal">Human capability is a designable, measurable, <em>engineerable</em> property of every complex system.</h2>
    <p class="reveal">LENS is a graduate specialization at Johns Hopkins that prepares practitioners to do this work—grounded in learning sciences and human systems integration, built for the domains where it matters most.</p>
    <div class="cta-buttons reveal">
      <a href={LENS_PROGRAM_URL} class="cta-btn" target="_blank" rel="noopener">Explore the LENS specialization</a>
      <a href={LECOMMONS_URL} class="cta-btn secondary" target="_blank" rel="noopener">Explore the wider learning engineering field</a>
    </div>
    <p class="cta-tertiary reveal">
      <a href={OVERVIEW_PDF_URL} target="_blank" rel="noopener">Download the LENS one-page overview (PDF)</a>
    </p>
  </section>
</Base>

<style>
  /* Dark homepage palette + typography. Custom properties live on
     body.dark-shell so children (including statement, evidence, etc.) inherit
     them through normal cascade. */
  :global(body.dark-shell) {
    --hp-navy: #0a1628;
    --hp-navy-mid: #132240;
    --hp-teal: #1a8a7d;
    --hp-teal-light: #2cc4b3;
    --hp-gold: #d4a843;
    --hp-cream: #f5f0e8;
    --hp-text-muted: #8a9ab5;
    --hp-serif: "Instrument Serif", Georgia, "Times New Roman", serif;
    --hp-sans: "DM Sans", -apple-system, BlinkMacSystemFont, "Inter", sans-serif;
  }

  /* HERO */
  .hero {
    min-height: 88vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 6rem 4rem 6rem;
    position: relative;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 55%;
    height: 100%;
    background: radial-gradient(ellipse at 70% 40%, rgba(26, 138, 125, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-label {
    font-family: var(--hp-sans);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--hp-teal-light);
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp 0.8s 0.3s forwards;
  }
  .hero h1 {
    font-family: var(--hp-serif);
    font-weight: 400;
    font-size: clamp(3.2rem, 7vw, 6.5rem);
    line-height: 1.05;
    max-width: 900px;
    color: var(--hp-cream);
    margin: 0;
    opacity: 0;
    animation: fadeUp 0.8s 0.5s forwards;
  }
  .hero h1 em { font-style: italic; color: var(--hp-teal-light); }
  .hero-sub {
    margin: 2.5rem 0 0;
    font-family: var(--hp-sans);
    font-size: 1.25rem;
    font-weight: 300;
    line-height: 1.7;
    max-width: 600px;
    color: var(--hp-text-muted);
    opacity: 0;
    animation: fadeUp 0.8s 0.7s forwards;
  }
  .hero-line {
    width: 80px;
    height: 2px;
    background: var(--hp-gold);
    margin-top: 3rem;
    opacity: 0;
    animation: fadeUp 0.8s 0.9s forwards;
  }
  .scroll-cue {
    position: absolute;
    bottom: 3rem;
    left: 4rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--hp-sans);
    color: var(--hp-text-muted);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0;
    animation: fadeUp 0.8s 1.2s forwards;
  }
  .scroll-cue .line { width: 40px; height: 1px; background: var(--hp-text-muted); }

  /* STATEMENTS */
  .statement {
    padding: 8rem 4rem;
    border-top: 1px solid rgba(138, 154, 181, 0.1);
    position: relative;
  }
  .statement-number {
    font-family: var(--hp-serif);
    font-size: 0.9rem;
    color: var(--hp-gold);
    margin-bottom: 1.5rem;
    letter-spacing: 0.05em;
  }
  .statement h2 {
    font-family: var(--hp-serif);
    font-weight: 400;
    font-size: clamp(2rem, 4.5vw, 3.8rem);
    line-height: 1.15;
    max-width: 800px;
    color: var(--hp-cream);
    margin: 0;
  }
  .statement h2 em { font-style: italic; color: var(--hp-teal-light); }
  .statement p {
    margin: 2rem 0 0;
    font-family: var(--hp-sans);
    font-size: 1.1rem;
    font-weight: 300;
    line-height: 1.8;
    max-width: 580px;
    color: var(--hp-text-muted);
  }
  .statement.right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
  }

  /* EVIDENCE STRIP */
  .evidence-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid rgba(138, 154, 181, 0.1);
  }
  .evidence-cell {
    padding: 4rem;
    border-right: 1px solid rgba(138, 154, 181, 0.1);
    position: relative;
  }
  .evidence-cell:last-child { border-right: none; }
  .evidence-cell .num {
    font-family: var(--hp-serif);
    font-size: 3.5rem;
    color: var(--hp-gold);
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .evidence-cell .unit {
    font-family: var(--hp-sans);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--hp-teal-light);
    margin-bottom: 1.5rem;
  }
  .evidence-cell p {
    font-family: var(--hp-sans);
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.6;
    color: var(--hp-text-muted);
    margin: 0;
    max-width: none;
  }
  .evidence-cell .cite {
    margin-top: 1.2rem;
    font-family: var(--hp-sans);
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.03em;
    color: rgba(138, 154, 181, 0.5);
    border-top: 1px solid rgba(138, 154, 181, 0.08);
    padding-top: 0.8rem;
  }

  /* DOMAINS */
  .domains {
    padding: 8rem 4rem;
    border-top: 1px solid rgba(138, 154, 181, 0.1);
  }
  .domains-header { margin-bottom: 4rem; }
  .domains-header h2 {
    font-family: var(--hp-serif);
    font-weight: 400;
    font-size: clamp(2rem, 3.5vw, 3rem);
    color: var(--hp-cream);
    margin: 0 0 1rem;
  }
  .domains-header p {
    font-family: var(--hp-sans);
    font-size: 1rem;
    font-weight: 300;
    color: var(--hp-text-muted);
    max-width: 500px;
    margin: 0;
  }
  .domain-cards {
    display: grid;
    /* auto-fit so the seven cards flow into even rows at any width instead of
       leaving an orphan in a fixed 3-column grid. */
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .domain-card {
    background: var(--hp-navy-mid);
    border: 1px solid rgba(138, 154, 181, 0.1);
    padding: 2.5rem 2rem;
    transition: border-color 0.4s ease, transform 0.3s ease;
  }
  .domain-card:hover {
    border-color: var(--hp-teal);
    transform: translateY(-4px);
  }
  .domain-card .icon {
    font-size: 1.8rem;
    margin-bottom: 1.5rem;
    color: var(--hp-teal-light);
  }
  .domain-card h3 {
    font-family: var(--hp-serif);
    font-weight: 400;
    font-size: 1.5rem;
    color: var(--hp-cream);
    margin: 0 0 1rem;
  }
  .domain-card p {
    font-family: var(--hp-sans);
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--hp-text-muted);
    margin: 0;
    max-width: none;
  }

  /* CTA */
  .cta-section {
    padding: 10rem 4rem;
    text-align: center;
    position: relative;
    border-top: 1px solid rgba(138, 154, 181, 0.1);
  }
  .cta-section::before {
    content: '';
    position: absolute;
    bottom: 0; left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 60%;
    background: radial-gradient(ellipse at center bottom, rgba(26, 138, 125, 0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .cta-equation {
    font-family: var(--hp-sans);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--hp-gold);
    margin: 0 0 1.5rem;
  }
  .cta-section h2 {
    font-family: var(--hp-serif);
    font-weight: 400;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    color: var(--hp-cream);
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.2;
  }
  .cta-section h2 em { font-style: italic; color: var(--hp-teal-light); }
  .cta-section p {
    margin: 1.5rem auto 0;
    font-family: var(--hp-sans);
    font-size: 1.05rem;
    font-weight: 300;
    color: var(--hp-text-muted);
    max-width: 500px;
  }
  .cta-buttons {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 3rem;
    position: relative;
  }
  .cta-btn {
    display: inline-block;
    padding: 1rem 3rem;
    background: transparent;
    border: 1px solid var(--hp-gold);
    color: var(--hp-gold);
    font-family: var(--hp-sans);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.3s, color 0.3s, border-color 0.3s;
  }
  .cta-btn:hover { background: var(--hp-gold); color: var(--hp-navy); }
  .cta-btn.secondary { border-color: var(--hp-text-muted); color: var(--hp-text-muted); }
  .cta-btn.secondary:hover { background: var(--hp-text-muted); color: var(--hp-navy); }
  .cta-tertiary {
    margin: 2rem auto 0;
    font-family: var(--hp-sans);
    font-size: 0.85rem;
    color: var(--hp-text-muted);
    max-width: none;
    position: relative;
  }
  .cta-tertiary a {
    color: var(--hp-text-muted);
    text-decoration: none;
    border-bottom: 1px solid rgba(138, 154, 181, 0.3);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }
  .cta-tertiary a:hover {
    color: var(--hp-teal-light);
    border-bottom-color: var(--hp-teal-light);
  }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  @media (prefers-reduced-motion: reduce) {
    .hero-label, .hero h1, .hero-sub, .hero-line, .scroll-cue { animation: none; opacity: 1; }
    .reveal { opacity: 1; transform: none; transition: none; }
    .domain-card { transition: none; }
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .hero { padding: 5rem 2rem; min-height: 80vh; }
    .statement { padding: 5rem 2rem; }
    .statement.right { align-items: flex-start; text-align: left; }
    .evidence-strip { grid-template-columns: 1fr; }
    .evidence-cell {
      border-right: none;
      border-bottom: 1px solid rgba(138, 154, 181, 0.1);
      padding: 3rem 2rem;
    }
    .evidence-cell:last-child { border-bottom: none; }
    .domain-cards { grid-template-columns: 1fr; }
    .domains { padding: 5rem 2rem; }
    .cta-section { padding: 6rem 2rem; }
    .scroll-cue { display: none; }
  }
</style>

<script is:inline>
  // Progressive enhancement: fade-in on scroll for elements marked .reveal.
  // Falls back to the CSS opacity:0 baseline if Intersection Observer is
  // missing; @media (prefers-reduced-motion) forces all reveals visible.
  (function () {
    var nodes = document.querySelectorAll('.reveal');
    if (!('IntersectionObserver' in window)) {
      nodes.forEach(function (n) { n.classList.add('visible'); });
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.15 });
    nodes.forEach(function (n) { io.observe(n); });
  })();
</script>
</content>
</invoke>