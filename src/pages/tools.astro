---
import Base from "../layouts/Base.astro";
import SectionHero from "../components/SectionHero.astro";
import SectionGrid from "../components/SectionGrid.astro";
import LecommonsCallout from "../components/LecommonsCallout.astro";
import { getCollection } from "astro:content";

const entries = await getCollection("tools");
---

<Base title="Tools · LENS" active="tools">
  <SectionHero
    eyebrow="Tools"
    title="Platforms, systems &amp; software"
    claim="Learning engineering needs instruments — for capturing behavior, modeling learners, authoring content, and feeding the evidence loop."
    question="What platforms and systems do learning engineers build on?"
    count={entries.length}
  />
  <LecommonsCallout path="tools/" label="the full catalog of LE platforms and tools" />
  <SectionGrid
    collection="tools"
    formatOrder={["tool", "platform"]}
    groupHeadings={{
      tool: "Tools",
      platform: "Platforms",
    }}
  />
</Base>
